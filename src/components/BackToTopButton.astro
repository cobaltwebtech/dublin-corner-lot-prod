---
import ArrowUpBold from "@/icons/arrow-up-bold.svg";
---

<button
  type="button"
  id="back-to-top"
  class="border-border bg-offset text-default invisible fixed right-5 bottom-5 cursor-pointer border-2 p-2 opacity-0 shadow-lg transition-opacity duration-300"
  aria-label="Back to top"
>
  <ArrowUpBold class="size-8" />
</button>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const backToTopButton = document.getElementById("back-to-top");

    function toggleBackToTopButton() {
      if (window.scrollY > 200) {
        backToTopButton?.classList.remove("opacity-0", "invisible");
        backToTopButton?.classList.add("opacity-100", "visible");
      } else {
        backToTopButton?.classList.add("opacity-0", "invisible");
        backToTopButton?.classList.remove("opacity-100", "visible");
      }
    }

    function scrollToTop() {
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    }

    window.addEventListener("scroll", toggleBackToTopButton);
    backToTopButton?.addEventListener("click", scrollToTop);
  });
</script>
