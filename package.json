{
  "name": "dublin-corner-lot",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "biome format --write",
    "lint": "biome lint",
    "astro": "astro",
    "upforce": "pnpm up --latest --recursive '*'",
    "up:astro": "pnpx @astrojs/upgrade",
    "up:biome": "pnpm up @biomejs/biome@latest && pnpm biome migrate --write",
    "clean": "rimraf dist .astro node_modules yarn.lock pnpm-lock.yaml .yarn .netlify"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.7",
    "@astrojs/sitemap": "3.7.2",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "6.1.8",
    "astro-compressor": "^1.3.0",
    "lenis": "^1.3.23",
    "micromodal": "^0.6.1",
    "resend": "^6.12.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/forms": "0.5.10",
    "@types/cloudflare-turnstile": "^0.2.2",
    "@types/micromodal": "^0.3.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
